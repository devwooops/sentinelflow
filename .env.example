# SentinelFlow v0.1 local configuration reference.
# Copy to an ignored local environment file. Keep every secret value local.

SENTINELFLOW_ENV=development
# Select exactly one analysis consumer. Replace this value with `live-ai` only
# when explicitly enabling the OpenAI-backed worker; do not combine profiles.
COMPOSE_PROFILES=stub-ai

# Gateway data plane
SENTINELFLOW_SERVICE_LABEL=demo-app
GATEWAY_LISTEN_ADDR=:8080
# Compose operational metrics use the separate, internal-only observability
# network. A direct local process may use the loopback default instead.
GATEWAY_METRICS_LISTEN_ADDR=172.29.0.2:9090
GATEWAY_PUBLIC_HOST=localhost:8080
GATEWAY_UPSTREAM_URL=http://demo-origin:8081
GATEWAY_UPSTREAM_HOST=demo-origin
# Must match the unpublished Compose origin network; enforced on resolve and dial.
GATEWAY_ORIGIN_CIDRS=172.30.0.0/24
GATEWAY_MAX_HEADER_BYTES=32768
GATEWAY_MAX_REQUEST_TARGET_BYTES=4096
GATEWAY_MAX_CLASSIFICATION_PATH_BYTES=2048
GATEWAY_MAX_BODY_BYTES=10485760
GATEWAY_HEADER_READ_TIMEOUT=5s
GATEWAY_REQUEST_TIMEOUT=30s
GATEWAY_UPSTREAM_TIMEOUT=30s
GATEWAY_IDLE_TIMEOUT=60s
GATEWAY_EVENT_QUEUE_CAPACITY=10000
GATEWAY_EVENT_BATCH_SIZE=100
GATEWAY_EVENT_MAX_BATCH_BYTES=262144
GATEWAY_EVENT_FLUSH_INTERVAL=100ms
GATEWAY_SENDER_CHECKPOINT_FILE=/var/lib/sentinelflow-gateway/sender-state.json
GATEWAY_TLS_CERT_FILE=
GATEWAY_TLS_KEY_FILE=
PATH_CATALOG_VERSION=path-catalog-v1
AUTH_ROUTE_PATH=/login
AUTH_ROUTE_LABEL=login

# Demo application and API listeners are bound to separate fixed private networks.
DEMO_ORIGIN_HTTP_LISTEN_ADDR=172.30.0.10:8081
# Prefer the Gateway's exact origin-network address; /24 is the broadest allowed value.
DEMO_GATEWAY_PEER_CIDRS=172.30.0.2/32
INTERNAL_API_INGEST_LISTEN_ADDR=172.31.0.10:8082
API_MANAGEMENT_LISTEN_ADDR=:8083
API_MANAGEMENT_PUBLISHED_HOST=127.0.0.1

# Internal event delivery. Scope each sender key to its identity and endpoint.
# HMAC keys are base64-encoded random values of at least 32 bytes.
# Key IDs rotate with their HMAC key. Binding IDs are canonical UUIDs that
# remain stable for the lifetime of one generated environment. Config hashes
# are lowercase SHA-256 over the explicit domain-separated nonsecret producer
# configuration; they never contain a key or account-hash secret.
INTERNAL_GATEWAY_INGEST_URL=http://api:8082/internal/v1/gateway-events
INTERNAL_AUTH_INGEST_URL=http://api:8082/internal/v1/auth-events
GATEWAY_EVENT_SENDER_ID=gateway-01
GATEWAY_EVENT_HMAC_KEY=
GATEWAY_EVENT_HMAC_KEY_ID=
GATEWAY_EXPECTED_SOURCE_BINDING_ID=
GATEWAY_SOURCE_CONFIG_SHA256=
AUTH_EVENT_SENDER_ID=demo-app
AUTH_EVENT_SERVICE_LABEL=demo-app
AUTH_EVENT_HMAC_KEY=
AUTH_EVENT_HMAC_KEY_ID=
AUTH_EXPECTED_SOURCE_BINDING_ID=
AUTH_SOURCE_CONFIG_SHA256=
AUTH_ACCOUNT_HASH_KEY=
AUTH_EVENT_SENDER_CHECKPOINT_FILE=/var/lib/sentinelflow-auth-adapter/sender-state.json
AUTH_EVENT_BINDING_TIMEOUT=5m
EVENT_MAX_FUTURE_SKEW=60s
EVENT_MAX_PAST_SKEW=5m

# Persistence. Supply distinct least-privilege PostgreSQL URLs outside Git.
# Demo URLs use canonical `postgresql` URLs with the fixed database and an
# explicit isolated-network `sslmode=disable`; no startup/runtime query options
# are permitted.
# DATABASE_WORKER_URL is shared by the always-on deterministic detector,
# provider-independent validation worker, and the selected analysis worker;
# none receives migration, API, read-only, dispatcher, or retention database
# credentials. The retention worker receives only its dedicated URL and may
# invoke one database-owned coordinator function. The lifecycle worker receives
# a different dedicated URL and may invoke only the three versioned claim,
# commit, and failure functions for read-only inspection scheduling.
DATABASE_MIGRATION_URL=
DATABASE_API_URL=
DATABASE_WORKER_URL=
DATABASE_READ_URL=
DATABASE_DISPATCHER_URL=
DATABASE_RETENTION_URL=
DATABASE_LIFECYCLE_URL=
DATABASE_METRICS_URL=
# Demo-only one-shot roles. The importer can write the immutable fixture
# ledger; the activator can only create/reattach the two runtime activations.
# Neither credential belongs in an always-on worker.
DATABASE_DEMO_IMPORTER_URL=
DATABASE_DEMO_ACTIVATOR_URL=
RETENTION_INTERVAL=1h
RETENTION_RUN_TIMEOUT=5m
RETENTION_MAX_ROWS=1000
LIFECYCLE_SCHEDULER_ID=lifecycle-scheduler-v1
LIFECYCLE_LEASE_OWNER=lifecycleworker-01
LIFECYCLE_LEASE_DURATION=10s
LIFECYCLE_RETRY_BACKOFF=1s
LIFECYCLE_POLL_INTERVAL=250ms
LIFECYCLE_CLEANUP_TIMEOUT=1s
CONTROL_METRICS_LISTEN_ADDR=172.29.0.3:9091
CONTROL_METRICS_SCRAPE_TIMEOUT=2s

# OpenAI Responses API. Supply the API key outside Git.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_REASONING_EFFORT=medium
OPENAI_STORE=false
OPENAI_INPUT_SCHEMA_FILE=contracts/ai/sentinelflow_analysis_input_v1.schema.json
OPENAI_SYSTEM_PROMPT_FILE=contracts/ai/sentinelflow_system_prompt_v1.txt
OPENAI_OUTPUT_SCHEMA_FILE=contracts/ai/sentinelflow_analysis_v1.schema.json
OPENAI_MAX_EVIDENCE_REFS=50
OPENAI_MAX_INPUT_BYTES=12288
OPENAI_MAX_OUTPUT_TOKENS=2048
OPENAI_TIMEOUT=30s
OPENAI_MAX_TRANSIENT_RETRIES=1
OPENAI_MAX_CONCURRENCY=2
OPENAI_DAILY_BUDGET_USD=10
# Versioned operator-supplied rates; missing rates disable live AI.
OPENAI_RATE_CARD_VERSION=
OPENAI_INPUT_USD_PER_1M_TOKENS=
OPENAI_CACHED_INPUT_USD_PER_1M_TOKENS=
OPENAI_OUTPUT_USD_PER_1M_TOKENS=
OPENAI_BUDGET_TIMEZONE=UTC

# Single-administrator reference profile. Generate all values locally.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_ARGON2ID_HASH=
SESSION_HMAC_KEY=
# Exact browser Origin allowlist. Plain HTTP is accepted only for localhost.
ADMIN_ALLOWED_ORIGINS=http://localhost:4173,http://localhost:5173
# Production API requires tls and an __Host- cookie name.
ADMIN_COOKIE_TRANSPORT=explicit-local-test
ADMIN_SESSION_COOKIE_NAME=sentinelflow_admin
SESSION_TTL=8h
SESSION_IDLE_TIMEOUT=30m
HIL_REAUTH_AFTER=15m
HIL_CHALLENGE_TTL=5m
HIL_DECISION_RATE_LIMIT_PER_MINUTE=5
ADMIN_LOGIN_RATE_LIMIT_PER_SOURCE_PER_MINUTE=5
ADMIN_LOGIN_RATE_LIMIT_GLOBAL_PER_MINUTE=20

# Detector and incident defaults
DETECT_PATH_SCAN_UNIQUE_PATHS=8
DETECT_PATH_SCAN_WINDOW=60s
DETECT_SUSPICIOUS_PATH_IDS=admin_console,env_file,git_config,wp_admin,phpmyadmin,server_status,actuator_env,backup_archive
DETECT_REQUEST_BURST_COUNT=120
DETECT_REQUEST_BURST_WINDOW=10s
DETECT_BRUTE_FORCE_FAILURES=10
DETECT_BRUTE_FORCE_WINDOW=60s
DETECT_CREDENTIAL_STUFFING_FAILURES=20
DETECT_CREDENTIAL_STUFFING_UNIQUE_ACCOUNTS=8
DETECT_CREDENTIAL_STUFFING_WINDOW=5m
INCIDENT_CORRELATION_WINDOW=5m
INCIDENT_CLOSE_AFTER=15m
INCIDENT_REOPEN_WITHIN=30m

# Policy validation and isolated executor
NFT_BINARY=/usr/sbin/nft
# Pin these to the exact bytes and normalized version in the validation/executor image.
NFT_BINARY_EXPECTED_SHA256=
NFT_EXPECTED_VERSION=
NFT_FAMILY=inet
NFT_TABLE=sentinelflow
NFT_BLACKLIST_SET=blacklist_ipv4
NFT_INPUT_CHAIN=gateway_input
NFT_PROTECTED_TCP_PORT=8080
NFT_INPUT_PRIORITY=0
NFT_BASE_CHAIN_SCHEMA_VERSION=nft-base-chain-v1
NFT_BASE_CHAIN_CONTRACT=contracts/enforcement/nft_base_chain_v1.nft
NFT_BASE_CHAIN_EXPECTED_SHA256=2d6476f6297f9b135032934bc557110541bae7eb2fe16fe29be70d20d0f4c488
NFT_BASE_CHAIN_LIVE_CONTRACT=contracts/enforcement/nft_base_chain_v1.live.json
NFT_BASE_CHAIN_LIVE_EXPECTED_SHA256=d5582a75817d349b12f292d212483bb0c2a5db66afde7d73c6d11050a5eb5997
NFT_VALIDATOR_SOCKET=/run/sentinelflow-validator/validator.sock
EXECUTOR_SOCKET=/run/sentinelflow-executor/executor.sock
EXECUTOR_REPLAY_JOURNAL=/var/lib/sentinelflow-executor/replay.json
# `bootstrap` is accepted only by the executor in an explicitly proven demo/test namespace.
EXECUTOR_STARTUP_MODE=verify
EXECUTOR_MAX_FRAME_BYTES=16384
EXECUTOR_IO_TIMEOUT=2s
DISPATCH_CAPABILITY_TTL=60s
DISPATCHER_SIGNING_PRIVATE_KEY_FILE=
EXECUTOR_DISPATCH_PUBLIC_KEY_FILE=
EXECUTOR_RESULT_PRIVATE_KEY_FILE=
DISPATCHER_RESULT_PUBLIC_KEY_FILE=
BLOCK_TTL_MIN=1m
BLOCK_TTL_DEFAULT=30m
BLOCK_TTL_MAX=24h
VALIDATION_TTL=5m
APPROVAL_TTL=5m
HISTORICAL_IMPACT_LOOKBACK=24h
# Adds to non-disableable built-in protected ranges; it never removes them.
PROTECTED_IPV4_CONTRACT=contracts/enforcement/protected_ipv4_v1.json
PROTECTED_IPV4_EXPECTED_SHA256=d3dfb63a573925e19f29e8595fd5574bc441a9c468d2f9ef6d2f004abb101104
PROTECTED_CIDRS=
PROTECTED_ORIGIN_IPV4=
PROTECTED_GATEWAY_IPV4=
# Leave empty when the executor shares the Gateway address in the private namespace.
PROTECTED_EXECUTOR_IPV4=
PROTECTED_MANAGEMENT_IPV4=
# Required by the validation worker; use the exact current administrator source IPv4.
PROTECTED_CURRENT_ADMIN_IPV4=
# Never enable outside the asserted disposable demo/test namespace.
DEMO_ALLOW_RFC5737=false
DEMO_ENFORCEMENT_ISOLATION_VERIFIED=false
DEMO_HOST_RULESET_UNCHANGED=false
DEMO_CLIENT_CIDR=203.0.113.0/24
DEMO_ATTACK_SOURCE_IP=203.0.113.20
DEMO_TEST_CLOCK=2026-07-18T02:00:00Z
# One exact CLI scenario: normal, credential-stuffing, brute-force, path-scan,
# or request-burst. The simulator intentionally has no aggregate mixed mode.
SIMULATOR_SCENARIO=normal
DEMO_HISTORY_FIXTURE_DATASET=/app/contracts/fixtures/demo_history_dataset_v1.json
DEMO_HISTORY_SIGNED_ENVELOPE_FILE=/run/sentinelflow-demo-history/signed-manifest.json
# Generated per run by cmd/democonfig. These values are public assertions,
# not signing secrets; the corresponding private key is never serialized.
DEMO_HISTORY_PUBLIC_KEY_B64URL=
DEMO_HISTORY_RUN_SCOPE=
DEMO_HISTORY_IMPORT_ID=
DEMO_HISTORY_CLOCK_AT=
DEMO_HISTORY_IMPACT_SOURCE_HEALTH_DIGEST=
# Raw 32-byte, per-consumer capabilities generated into ignored local files.
# Each always-on consumer receives only its own read-only named-volume copy;
# the one-shot demo activator is the only service that receives both.
DEMO_HISTORY_ANALYSIS_ACTIVATION_SECRET_FILE=/run/secrets/sentinelflow-demo-history-analysis/activation-capability
DEMO_HISTORY_VALIDATION_ACTIVATION_SECRET_FILE=/run/secrets/sentinelflow-demo-history-validation/activation-capability
CONTRACT_VECTOR_BUNDLE=contracts/vectors/contract_vectors_v1.json

# Retention
EVENT_EVIDENCE_RETENTION=168h
INCIDENT_AI_POLICY_RETENTION=720h
AUDIT_RETENTION=2160h
