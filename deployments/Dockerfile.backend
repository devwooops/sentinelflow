# syntax=docker/dockerfile:1.12@sha256:93bfd3b68c109427185cd78b4779fc82b484b0b7618e36d0f104d4d801e66d25

FROM golang:1.25.12-alpine@sha256:56961d79ea8129efddcc0b8643fd8a5416b4e6228cfd477e3fd61deb2672c587 AS build

ARG VERSION=dev
ARG SOURCE_DATE_EPOCH=0

WORKDIR /src

COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

COPY cmd ./cmd
COPY internal ./internal

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    set -eu; \
    mkdir -p /out; \
	for command in api controlmetricsexporter demoactivator demoapp detector dispatcher executor exporttool gateway retentionworker simulator thresholdreport validator worker stubworker validationworker lifecycleworker; do \
        CGO_ENABLED=0 go build \
            -trimpath \
            -buildvcs=false \
            -ldflags="-s -w -X github.com/devwooops/sentinelflow/internal/buildinfo.Version=${VERSION}" \
            -o "/out/${command}" \
	            "./cmd/${command}"; \
	done; \
	CGO_ENABLED=0 go build \
	    -trimpath \
	    -buildvcs=false \
	    -ldflags="-s -w -X github.com/devwooops/sentinelflow/internal/buildinfo.Version=${VERSION}" \
	    -o /out/historyimporter \
	    ./cmd/historyimporter; \
	CGO_ENABLED=0 go build \
	    -trimpath \
	    -buildvcs=false \
	    -ldflags="-s -w -X github.com/devwooops/sentinelflow/internal/buildinfo.Version=${VERSION}" \
	    -o /out/sentinelflow-recoverytool \
	    ./cmd/recoverytool

FROM alpine:3.24@sha256:28bd5fe8b56d1bd048e5babf5b10710ebe0bae67db86916198a6eec434943f8b

ARG VERSION=dev
ARG SOURCE_DATE_EPOCH=0

RUN apk add --no-cache \
        ca-certificates=20260611-r0 \
        nftables=1.1.6-r1 \
        tzdata=2026c-r0 \
    && addgroup -S -g 65532 sentinelflow \
    && adduser -S -D -H -u 65532 -G sentinelflow sentinelflow \
    && install -d -o 65532 -g 65532 -m 0750 /app \
    && rm -f /var/log/apk.log

WORKDIR /app

COPY --from=build /out/ /usr/local/bin/
COPY --chown=0:0 contracts ./contracts
RUN find /app/contracts -type d -exec chmod 0555 {} + \
    && find /app/contracts -type f -exec chmod 0444 {} +

LABEL org.opencontainers.image.title="SentinelFlow" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.licenses="MIT"

USER 65532:65532

CMD ["/usr/local/bin/api"]
