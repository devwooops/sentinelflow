{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelflow.example/contracts/events/source_coverage_v1.schema.json",
  "title": "SentinelFlow positive source coverage v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "source-coverage-v1" },
    "event_id": { "$ref": "#/$defs/uuid" },
    "idempotency_key": { "$ref": "#/$defs/digest" },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "affected_sender_epoch": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{22}$"
    },
    "segment_id": { "$ref": "#/$defs/uuid" },
    "previous_coverage_digest": {
      "oneOf": [
        { "$ref": "#/$defs/digest" },
        { "type": "null" }
      ]
    },
    "coverage_start": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "coverage_end": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "covered_through_batch_id": { "$ref": "#/$defs/uuid" },
    "covered_through_sequence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "state": { "const": "complete" }
  },
  "required": [
    "schema_version",
    "event_id",
    "idempotency_key",
    "source_id",
    "affected_sender_epoch",
    "segment_id",
    "previous_coverage_digest",
    "coverage_start",
    "coverage_end",
    "covered_through_batch_id",
    "covered_through_sequence",
    "state"
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
