{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelflow.example/contracts/events/source_health_v1.schema.json",
  "title": "SentinelFlow source health event v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "source-health-v1"
    },
    "event_id": {
      "$ref": "#/$defs/uuid"
    },
    "idempotency_key": {
      "$ref": "#/$defs/digest"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "cause": {
      "enum": [
        "queue_overflow",
        "delivery_outage",
        "rejected_batch",
        "sequence_gap",
        "permanent_loss",
        "unclean_restart",
        "unknown_loss",
        "recovered"
      ]
    },
    "state": {
      "enum": [
        "degraded",
        "lost",
        "recovered"
      ]
    },
    "affected_sender_epoch": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{22}$"
    },
    "sequence_start": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "sequence_end": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "interval_start": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "interval_end": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "dropped_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "detail_code": {
      "enum": [
        "none",
        "known_range",
        "unknown_range",
        "receiver_rejected",
        "sender_restart",
        "delivery_restored"
      ]
    }
  },
  "required": [
    "schema_version",
    "event_id",
    "idempotency_key",
    "occurred_at",
    "source_id",
    "cause",
    "state",
    "affected_sender_epoch",
    "sequence_start",
    "sequence_end",
    "interval_start",
    "interval_end",
    "dropped_count",
    "detail_code"
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
