{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelflow.example/contracts/enforcement/evidence_snapshot_v1.schema.json",
  "title": "SentinelFlow immutable evidence snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "evidence-snapshot-v1"
    },
    "snapshot_id": {
      "$ref": "#/$defs/uuid"
    },
    "incident_id": {
      "$ref": "#/$defs/uuid"
    },
    "incident_version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2147483647
    },
    "source_ipv4": {
      "type": "string",
      "format": "ipv4",
      "minLength": 7,
      "maxLength": 15
    },
    "service_label": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{0,63}$"
    },
    "window_start": {
      "type": "string",
      "format": "date-time"
    },
    "window_end": {
      "type": "string",
      "format": "date-time"
    },
    "source_health_digest": {
      "$ref": "#/$defs/digest"
    },
    "event_ids": {
      "$ref": "#/$defs/ordered_event_ids"
    },
    "signal_ids": {
      "$ref": "#/$defs/ordered_signal_ids"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "schema_version",
    "snapshot_id",
    "incident_id",
    "incident_version",
    "source_ipv4",
    "service_label",
    "window_start",
    "window_end",
    "source_health_digest",
    "event_ids",
    "signal_ids",
    "created_at"
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "ordered_event_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "description": "Complete duplicate-free retained event IDs in strict ascending UTF-8 byte order; application validation rejects rather than samples, truncates, or reorders, and fails input_too_large above this bound.",
      "items": {
        "$ref": "#/$defs/uuid"
      }
    },
    "ordered_signal_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "description": "Duplicate-free model-addressable signal IDs in strict ascending UTF-8 byte order; application validation rejects rather than reorders.",
      "items": {
        "$ref": "#/$defs/uuid"
      }
    }
  }
}
