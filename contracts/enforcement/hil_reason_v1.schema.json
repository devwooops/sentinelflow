{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelflow.example/contracts/enforcement/hil_reason_v1.schema.json",
  "title": "SentinelFlow administrator HIL reason v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "hil-reason-v1"
    },
    "reason_code": {
      "enum": [
        "threat_confirmed",
        "false_positive",
        "business_exception",
        "emergency_revoke",
        "operator_request",
        "other"
      ]
    },
    "reason_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^(?:[^\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F\\u007F])+$"
    }
  },
  "required": [
    "schema_version",
    "reason_code",
    "reason_text"
  ]
}
