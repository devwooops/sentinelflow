{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelflow.example/contracts/enforcement/protected_ipv4_effective_config_v1.schema.json",
  "title": "SentinelFlow effective protected IPv4 configuration v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "protected-ipv4-effective-config-v1"
    },
    "static_contract_digest": {
      "$ref": "#/$defs/digest"
    },
    "configured_protected_cidrs": {
      "$ref": "#/$defs/ordered_cidrs"
    },
    "runtime_protected_ipv4": {
      "type": "array",
      "maxItems": 64,
      "description": "Canonical IPv4 addresses for Gateway, executor, management, origin, and current administrator path, in ascending address-byte order.",
      "items": {
        "type": "string",
        "format": "ipv4",
        "minLength": 7,
        "maxLength": 15
      }
    },
    "demo_exception_profile": {
      "enum": [
        "disabled",
        "isolated-rfc5737"
      ]
    },
    "demo_exception_cidrs": {
      "type": "array",
      "maxItems": 3,
      "description": "Empty unless isolated-rfc5737; application validation permits only 192.0.2.0/24, 198.51.100.0/24, and 203.0.113.0/24 in this exact order.",
      "items": {
        "enum": [
          "192.0.2.0/24",
          "198.51.100.0/24",
          "203.0.113.0/24"
        ]
      }
    }
  },
  "required": [
    "schema_version",
    "static_contract_digest",
    "configured_protected_cidrs",
    "runtime_protected_ipv4",
    "demo_exception_profile",
    "demo_exception_cidrs"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "demo_exception_profile": {
            "const": "disabled"
          }
        }
      },
      "then": {
        "properties": {
          "demo_exception_cidrs": {
            "type": "array",
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "demo_exception_profile": {
            "const": "isolated-rfc5737"
          }
        }
      },
      "then": {
        "properties": {
          "demo_exception_cidrs": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "prefixItems": [
              {
                "const": "192.0.2.0/24"
              },
              {
                "const": "198.51.100.0/24"
              },
              {
                "const": "203.0.113.0/24"
              }
            ],
            "items": false
          }
        }
      }
    }
  ],
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "ordered_cidrs": {
      "type": "array",
      "maxItems": 256,
      "description": "Duplicate-free canonical IPv4 CIDRs in ascending network-address then prefix order; configured values only add protection.",
      "items": {
        "type": "string",
        "pattern": "^(?:[0-9]{1,3}\\.){3}[0-9]{1,3}/(?:[0-9]|[12][0-9]|3[0-2])$"
      }
    }
  }
}
