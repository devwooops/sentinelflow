{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentinelflow.local/contracts/tuning/threshold_corpus_v1.schema.json",
  "title": "SentinelFlow offline threshold comparison corpus v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "dataset_id", "cases"],
  "properties": {
    "schema_version": { "const": "threshold-comparison-corpus-v1" },
    "dataset_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "rule_id",
        "expected_attack",
        "evidence_state",
        "observed",
        "false_positive_factors"
      ],
      "properties": {
        "case_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
        "rule_id": {
          "enum": ["path_scan.v1", "request_burst.v1", "login_bruteforce.v1", "credential_stuffing.v1"]
        },
        "expected_attack": { "type": "boolean" },
        "evidence_state": { "enum": ["complete", "incomplete", "untrusted", "unverified"] },
        "observed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["raw_event_count", "unique_event_count", "distinct_count"],
          "properties": {
            "raw_event_count": { "type": "integer", "minimum": 0, "maximum": 1000000 },
            "unique_event_count": { "type": "integer", "minimum": 0, "maximum": 1000000 },
            "distinct_count": { "type": "integer", "minimum": 0, "maximum": 1000000 }
          }
        },
        "false_positive_factors": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "enum": ["none", "authorized_scanner", "load_test", "shared_nat", "credential_rotation"]
          }
        }
      }
    }
  }
}
